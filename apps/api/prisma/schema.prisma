generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum FarmType {
  BEEF
  DAIRY
  MIXED
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum AnimalStatus {
  ACTIVE
  DRY
  CULLED
  SOLD
  DEAD
}

enum EventType {
  HEAT
  INSEMINATION
  NATURAL_BREEDING
  PREGNANCY_DIAGNOSIS
  CALVING
  WEANING
  CULLING
}

enum PregnancyStatus {
  SUSPECTED
  CONFIRMED
  ABORTED
  COMPLETED
}

enum AlertType {
  HEAT_RETURN
  PRE_CALVING_13D
  PRE_CALVING_7D
  PRE_CALVING_3D
  DUE_DATE
  OVERDUE_NO_CALVING
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  farms             FarmMember[]
  events            ReproductiveEvent[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Farm {
  id        String   @id @default(uuid())
  name      String
  city      String?
  state     String?
  type      FarmType @default(BEEF)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members FarmMember[]
  animals Animal[]
  alerts  Alert[]

  @@map("farms")
}

model FarmMember {
  userId String   @map("user_id")
  farmId String   @map("farm_id")
  role   UserRole @default(VIEWER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@id([userId, farmId])
  @@map("farm_members")
}

model Animal {
  id        String       @id @default(uuid())
  farmId    String       @map("farm_id")
  earTag    String       @map("ear_tag")
  name      String?
  breed     String?
  birthDate DateTime?    @map("birth_date")
  weightKg  Decimal?     @map("weight_kg")
  status    AnimalStatus @default(ACTIVE)
  photoUrl  String?      @map("photo_url")
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  farm        Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  events      ReproductiveEvent[]
  pregnancies Pregnancy[]

  @@unique([farmId, earTag])
  @@map("animals")
}

model ReproductiveEvent {
  id        String    @id @default(uuid())
  animalId  String    @map("animal_id")
  userId    String?   @map("user_id")
  type      EventType
  eventDate DateTime  @map("event_date")
  result    Boolean?
  notes     String?   @db.Text
  extraData Json?     @map("extra_data")
  createdAt DateTime  @default(now()) @map("created_at")

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  createdPregnancy Pregnancy? @relation("BreedingEvent")

  @@map("reproductive_events")
}

model Pregnancy {
  id                String          @id @default(uuid())
  animalId          String          @map("animal_id")
  breedingEventId   String?         @unique @map("breeding_event_id")
  breedingDate      DateTime        @map("breeding_date")
  dueDate           DateTime        @map("due_date")
  actualCalvingDate DateTime?       @map("actual_calving_date")
  status            PregnancyStatus @default(SUSPECTED)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  animal        Animal             @relation(fields: [animalId], references: [id], onDelete: Cascade)
  breedingEvent ReproductiveEvent? @relation("BreedingEvent", fields: [breedingEventId], references: [id])
  alerts        Alert[]

  @@map("pregnancies")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Alert {
  id           String      @id @default(uuid())
  pregnancyId  String      @map("pregnancy_id")
  farmId       String      @map("farm_id")
  type         AlertType
  scheduledFor DateTime    @map("scheduled_for")
  status       AlertStatus @default(PENDING)
  recipients   Json        @default("[]")
  sentAt       DateTime?   @map("sent_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  pregnancy Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("alerts")
}
