generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoFazenda {
  CORTE
  LEITE
  MISTO
}

enum PapelUsuario {
  ADMIN
  EDITOR
  VISUALIZADOR
}

enum StatusAnimal {
  ATIVA
  SECA
  DESCARTADA
  VENDIDA
  MORTA
}

enum TipoEvento {
  CIO
  IA
  MONTA
  DIAGNOSTICO_GESTACAO
  PARTO
  DESMAME
  DESCARTE
}

enum StatusGestacao {
  SUSPEITA
  CONFIRMADA
  ABORTADA
  CONCLUIDA
}

enum TipoAlerta {
  CIO_RETORNO
  PRE_PARTO_13D
  PRE_PARTO_7D
  PRE_PARTO_3D
  DPP
  POS_DPP_SEM_REGISTRO
}

enum StatusAlerta {
  PENDENTE
  ENVIADO
  FALHOU
  CANCELADO
}

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  telefone     String?
  senhaHash    String   @map("senha_hash")
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  fazendas          UsuarioFazenda[]
  eventos           EventoReprodutivo[]
  pushSubscriptions PushSubscription[]

  @@map("usuarios")
}

model Fazenda {
  id           String      @id @default(uuid())
  nome         String
  cidade       String?
  estado       String?
  tipo         TipoFazenda @default(CORTE)
  criadoEm    DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime    @updatedAt @map("atualizado_em")

  usuarios UsuarioFazenda[]
  animais  Animal[]
  alertas  Alerta[]

  @@map("fazendas")
}

model UsuarioFazenda {
  usuarioId String      @map("usuario_id")
  fazendaId String      @map("fazenda_id")
  papel     PapelUsuario @default(VISUALIZADOR)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  fazenda Fazenda @relation(fields: [fazendaId], references: [id], onDelete: Cascade)

  @@id([usuarioId, fazendaId])
  @@map("usuario_fazenda")
}

model Animal {
  id           String       @id @default(uuid())
  fazendaId    String       @map("fazenda_id")
  brinco       String
  nome         String?
  raca         String?
  nascimento   DateTime?
  pesoKg       Decimal?     @map("peso_kg")
  status       StatusAnimal @default(ATIVA)
  fotoUrl      String?      @map("foto_url")
  observacoes  String?
  criadoEm    DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  fazenda   Fazenda             @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  eventos   EventoReprodutivo[]
  gestacoes Gestacao[]

  @@unique([fazendaId, brinco])
  @@map("animais")
}

model EventoReprodutivo {
  id           String     @id @default(uuid())
  animalId     String     @map("animal_id")
  usuarioId    String?    @map("usuario_id")
  tipo         TipoEvento
  dataEvento   DateTime   @map("data_evento")
  resultado    Boolean?
  observacoes  String?
  dadosExtras  Json?      @map("dados_extras")
  criadoEm    DateTime   @default(now()) @map("criado_em")

  animal   Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  gestacaoCriada Gestacao? @relation("EventoCobertura")

  @@map("eventos_reprodutivos")
}

model Gestacao {
  id                 String         @id @default(uuid())
  animalId           String         @map("animal_id")
  eventoCoberturaId  String?        @unique @map("evento_cobertura_id")
  dataCobertura      DateTime       @map("data_cobertura")
  dpp                DateTime
  dataPartoReal      DateTime?      @map("data_parto_real")
  status             StatusGestacao @default(SUSPEITA)
  criadoEm          DateTime       @default(now()) @map("criado_em")
  atualizadoEm       DateTime       @updatedAt @map("atualizado_em")

  animal          Animal             @relation(fields: [animalId], references: [id], onDelete: Cascade)
  eventoCobertura EventoReprodutivo? @relation("EventoCobertura", fields: [eventoCoberturaId], references: [id])
  alertas         Alerta[]

  @@map("gestacoes")
}

model PushSubscription {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Alerta {
  id           String       @id @default(uuid())
  gestacaoId   String       @map("gestacao_id")
  fazendaId    String       @map("fazenda_id")
  tipo         TipoAlerta
  dataDisparo  DateTime     @map("data_disparo")
  status       StatusAlerta @default(PENDENTE)
  destinatarios Json        @default("[]")
  enviadoEm    DateTime?    @map("enviado_em")
  criadoEm    DateTime     @default(now()) @map("criado_em")

  gestacao Gestacao @relation(fields: [gestacaoId], references: [id], onDelete: Cascade)
  fazenda  Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)

  @@map("alertas")
}
