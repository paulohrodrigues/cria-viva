DATABASE_URL="mysql://criaviva:criaviva123@localhost:3306/criaviva_dev"
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=replace-with-a-long-random-secret-in-production
FRONTEND_URL=http://localhost:3000
PORT=3001
CRON_SECRET=replace-with-a-secret-for-the-scheduler

# Web Push (generate a new pair with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Heroku: DATABASE_URL comes from the JawsDB MariaDB add-on (JAWSDB_MARIA_URL)
# Heroku: REDIS_URL comes from the Heroku Redis add-on (replaces REDIS_HOST/PORT)
